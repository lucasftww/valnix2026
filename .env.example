# ─── Supabase ─────────────────────────────────────────────────────────────
# Frontend (browser-safe, anon key — RLS protects data)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Server-side (Vercel Functions — NEVER prefix with VITE_)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Admin auth ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-strong-password
# Comma-separated allowed origins for /api/* CORS (defaults to valnix.com.br)
ADMIN_ALLOWED_ORIGINS=https://www.valnix.com.br,https://valnix.com.br

# ─── Meta CAPI ────────────────────────────────────────────────────────────
META_PIXEL_ID=
META_ACCESS_TOKEN=
# Browser-side pixel ID (must equal META_PIXEL_ID — used by bootstrap.ts).
VITE_META_PIXEL_ID=

# ─── Support / WhatsApp ───────────────────────────────────────────────────
# Used by FloatingContactButtons. Digits only, country code first,
# no + / spaces / dashes. Example: 5511999999999
VITE_WHATSAPP_NUMBER=

# ─── Payment gateway: Dice ────────────────────────────────────────────────
# Base URL — confirm with Dice support whether they have a separate prod host
# (e.g. https://api.use-dice.com). The credentials below are dice_live_* so
# they're production credentials regardless of which host you point at.
DICE_BASE_URL=https://dev.use-dice.com
DICE_CLIENT_ID=dice_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DICE_CLIENT_SECRET=dicesk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the URL Dice will POST to on status changes. Defaults
# to https://<request-host>/api/dice-webhook (Vercel infers this in prod).
# Setting it explicitly is a good idea so preview deploys don't accidentally
# receive production webhooks.
DICE_WEBHOOK_URL=https://www.valnix.com.br/api/dice-webhook

# REQUIRED — shared secret appended to webhook URL as ?secret=<value>.
# /api/dice-webhook refuses any POST without this. Without it, anyone could
# POST to the webhook and mark orders paid by guessing a UUID. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DICE_WEBHOOK_SECRET=
